                android:endX="72.5"
                android:endY="59.5"
                android:type="linear">
                <item android:offset="0.0" android:color="#2010B981" />
                <item android:offset="1.0" android:color="#4038BDF8" />
            </gradient>
        </aapt:attr>
        <aapt:attr name="android:strokeColor">
            <gradient
                android:startX="35.5"
                android:startY="40"
                android:endX="72.5"
                android:endY="59.5"
                android:type="linear">
                <item android:offset="0.0" android:color="#FBBF24" />
                <item android:offset="1.0" android:color="#10B981" />
